# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# AI (xAI Grok for newsletter synthesis)
XAI_API_KEY=xxx

# Twitter Data (Apify)
APIFY_API_KEY=xxx

# Auth — Twitter OAuth 2.0
TWITTER_CLIENT_ID=xxx
TWITTER_CLIENT_SECRET=xxx

# Auth — Google OAuth
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx

# Email (Resend)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=xxx

# Cron authentication
CRON_SECRET=xxx

# Stripe (payments)
STRIPE_SECRET_KEY=sk_xxx
STRIPE_PUBLISHABLE_KEY=pk_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# YouTube Transcripts (Supadata)
SUPADATA_API_KEY=xxx

# Audio dispatch (OpenAI TTS) — set PERSONAL_DISPATCH_AUDIO=1 to enable audio delivery to Telegram
OPENAI_API_KEY=sk-xxx
PERSONAL_DISPATCH_AUDIO=0

# Alpaca Trading API (BYO-keys flow uses these as env-default fallback)
ALPACA_KEY_ID=xxx
ALPACA_SECRET_KEY=xxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Alpaca Broker API (managed-account white-label flow)
# Sandbox: https://broker-api.sandbox.alpaca.markets
# Prod requires signed Broker API agreement.
BROKER_API_KEY_ID=xxx
BROKER_API_SECRET=xxx
BROKER_API_BASE_URL=https://broker-api.sandbox.alpaca.markets
